---
import '@fontsource-variable/cormorant';
import '@fontsource-variable/dm-sans';
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';

interface Props {
  title: string;
  description: string;
  url?: string;
}

const {
  title,
  description,
  url = Astro.url.href
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <SeoHead title={title} description={description} url={url} />
  </head>
  <body>
    <slot />
  </body>
</html>
